# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=temiryol-backend

# ─── MongoDB ─────────────────────────────────────────────
# Local: mongodb://localhost:27017/temiryol
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/temiryol
MONGODB_URI=mongodb://localhost:27017/temiryol

# ─── JWT ─────────────────────────────────────────────────
# IMPORTANT: production da string ni o'zgartiring (kamida 32 belgi)
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────
# Vergul bilan ajratilgan domain ro'yxati
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Auth ───────────────────────────────────────────────
# Bruteforce himoya: necha urinishdan keyin lock
MAX_LOGIN_ATTEMPTS=3
# Lock muddati (daqiqa)
LOGIN_LOCK_MINUTES=15

# ─── Test rejimi ─────────────────────────────────────────
# Frontenddan reportDateISO override qabul qilinadimi
ALLOW_DATE_OVERRIDE=true

# ─── Seed ────────────────────────────────────────────────
# Birinchi admin va developer kodlari (seed orqali yaratiladi)
SEED_ADMIN_CODE=9999
SEED_ADMIN_NAME=Bosh Admin
SEED_DEVELOPER_CODE=9998
SEED_DEVELOPER_NAME=Tizim Boshqaruvchisi
